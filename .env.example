# Garmin Connect credentials (required for sync)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# Optional: for local development (defaults to False for production)
# DJANGO_DEBUG=True

# Optional: for AI meal analysis
# MISTRAL_AI_API_KEY=your_key

# Optional: for production (defaults to dev key if unset)
# DJANGO_SECRET_KEY=your_secret_key
