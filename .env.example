# Garmin Connect credentials (required for Garmin sync)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# Supabase REST API (required for production data storage)
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_API_KEY=your_anon_or_service_role_key

# Optional: AI meal analysis
# MISTRAL_AI_API_KEY=your_key

# Optional: Django settings
# DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=your_secret_key
